{% extends 'catalog/base.html.twig' %}

{% block title %}Catálogo de Testes{% endblock %}

{% block body %}
    <section class="hero">
        <div class="hero-copy">
            <h1>Catálogo de Testes</h1>
            <p>Catálogo dos cenários realmente executados no API Platform, com payload, query string, resposta, histórico e rerun individual, por grupo ou geral a partir do que já foi gravado no SQLite.</p>
        </div>
        <div class="hero-stats">
            <article class="stat-card">
                <strong>Cenários</strong>
                <span>{{ summary.total_tests }}</span>
            </article>
            <article class="stat-card">
                <strong>Com payload</strong>
                <span>{{ summary.payload_tests }}</span>
            </article>
            <article class="stat-card">
                <strong>Execuções</strong>
                <span>{{ summary.total_runs }}</span>
            </article>
        </div>
    </section>

    <section class="panel">
        <div class="panel-header">
            <h2>Rerun geral</h2>
            <p>Executa novamente todos os cenários já gravados, usando a base {{ baseUrl }}.</p>
        </div>
        <div class="action-bar">
            <form method="post" action="{{ app.request.basePath ~ '/index.php/catalogo-testes/executar/geral' }}">
                <input type="hidden" name="q" value="{{ search }}">
                <input type="hidden" name="grupo" value="{{ selectedGroupCode }}">
                <input type="hidden" name="teste" value="{{ selectedTest ? selectedTest.code : '' }}">
                <button class="button button-primary" type="submit">Executar tudo</button>
            </form>
        </div>
    </section>

    <section class="group-grid">
        {% for group in groups %}
            <article class="group-card{% if selectedGroup and selectedGroup.code == group.code %} is-active{% endif %}">
                <div>
                    <h3>{{ group.name }}</h3>
                    <p>{{ group.description }}</p>
                </div>
                <div class="chips">
                    <span class="chip">{{ group.module }}</span>
                    <span class="chip">{{ group.payload_tests }} com payload</span>
                    <span class="chip">{{ group.total_tests }} cenários</span>
                </div>
                <div class="group-actions">
                    <a class="button button-secondary" href="{{ app.request.basePath ~ '/index.php/catalogo-testes?grupo=' ~ group.code ~ (search != '' ? '&q=' ~ search|url_encode : '') }}">Ver grupo</a>
                    <form method="post" action="{{ app.request.basePath ~ '/index.php/catalogo-testes/executar/grupo/' ~ group.code }}">
                        <input type="hidden" name="q" value="{{ search }}">
                        <input type="hidden" name="grupo" value="{{ group.code }}">
                        <input type="hidden" name="teste" value="{{ selectedTest ? selectedTest.code : '' }}">
                        <button class="button button-primary" type="submit">Executar grupo</button>
                    </form>
                </div>
            </article>
        {% endfor %}
    </section>

    <section class="layout">
        <aside class="panel">
            <div class="panel-header">
                <h2>Cenários gravados</h2>
                <p>Selecione um cenário já capturado no API Platform para inspecionar o payload e refazer a chamada.</p>
            </div>

            <form class="search-form" method="get" action="{{ app.request.basePath ~ '/index.php/catalogo-testes' }}">
                <input type="text" name="q" value="{{ search }}" placeholder="Buscar por nfe, cep, nfse, path...">
                <select name="grupo">
                    <option value="">Todos os grupos</option>
                    {% for group in groups %}
                        <option value="{{ group.code }}"{% if selectedGroupCode == group.code %} selected{% endif %}>{{ group.name }}</option>
                    {% endfor %}
                </select>
                <button class="button button-primary" type="submit">Filtrar</button>
                {% if search != '' or selectedGroupCode != '' %}
                    <a class="button button-secondary" href="{{ app.request.basePath ~ '/index.php/catalogo-testes' }}">Limpar</a>
                {% endif %}
            </form>

            {% if tests is empty %}
                <div class="empty">Nenhum cenário gravado encontrado para os filtros atuais.</div>
            {% else %}
                <div class="entity-list">
                    {% for test in tests %}
                        {% set lastRun = test.last_run %}
                        <a
                            class="entity-item{% if selectedTest and selectedTest.code == test.code %} is-active{% endif %}"
                            href="{{ app.request.basePath ~ '/index.php/catalogo-testes?teste=' ~ test.code
                                ~ (selectedGroupCode != '' ? '&grupo=' ~ selectedGroupCode : '')
                                ~ (search != '' ? '&q=' ~ search|url_encode : '')
                                ~ (selectedBatch ? '&lote=' ~ selectedBatch.id : '')
                            }}"
                        >
                            <strong>{{ test.name }}</strong>
                            <p>{{ test.description }}</p>
                            <div class="chips">
                                <span class="chip">{{ test.group_name }}</span>
                                <span class="chip">{{ test.method }}</span>
                                <span class="chip">{{ test.request_count }} uso(s)</span>
                                <span class="chip">{{ test.last_recorded_at ? test.last_recorded_at|date('d/m/Y H:i:s') : 'sem data' }}</span>
                                {% if lastRun %}
                                    <span class="chip{% if lastRun.success %} chip-success{% else %} chip-danger{% endif %}">
                                        {{ lastRun.success ? 'último ok' : 'último erro' }}
                                    </span>
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </aside>

        <main class="panel">
            {% if selectedTest %}
                <div class="panel-header">
                    <h2>{{ selectedTest.name }}</h2>
                    <p>{{ selectedTest.description }}</p>
                </div>

                <div class="details">
                    <div class="meta">
                        <span>{{ selectedTest.code }}</span>
                        <span>{{ selectedTest.group_name }}</span>
                        <span>{{ selectedTest.method }}</span>
                        <span>{{ selectedTest.request_count }} uso(s)</span>
                    </div>

                    <div class="action-row">
                        <form method="post" action="{{ app.request.basePath ~ '/index.php/catalogo-testes/executar/teste/' ~ selectedTest.code }}">
                            <input type="hidden" name="q" value="{{ search }}">
                            <input type="hidden" name="grupo" value="{{ selectedGroupCode != '' ? selectedGroupCode : selectedTest.group_code }}">
                            <input type="hidden" name="teste" value="{{ selectedTest.code }}">
                            <button class="button button-primary" type="submit">Rerun do cenário</button>
                        </form>

                        <form method="post" action="{{ app.request.basePath ~ '/index.php/catalogo-testes/executar/grupo/' ~ selectedTest.group_code }}">
                            <input type="hidden" name="q" value="{{ search }}">
                            <input type="hidden" name="grupo" value="{{ selectedTest.group_code }}">
                            <input type="hidden" name="teste" value="{{ selectedTest.code }}">
                            <button class="button button-secondary" type="submit">Rerun do grupo {{ selectedTest.group_name }}</button>
                        </form>
                    </div>

                    <div class="info-grid">
                        <div class="block">
                            <h4>Endpoint</h4>
                            <pre class="code-block"><code>{{ selectedTest.method }} {{ selectedTest.path }}{% if selectedTest.query_string %}?{{ selectedTest.query_string }}{% endif %}</code></pre>
                        </div>

                        <div class="block">
                            <h4>Base resolvida</h4>
                            <pre class="code-block"><code>{{ baseUrl }}</code></pre>
                        </div>
                    </div>

                    <div class="block">
                        <h4>Headers</h4>
                        <pre class="code-block"><code>{% for header in selectedTest.headers %}{{ header }}
{% else %}Sem headers adicionais.
{% endfor %}</code></pre>
                    </div>

                    <div class="block">
                        <h4>Payload</h4>
                        <pre class="code-block"><code>{{ selectedTest.request_body ?? 'Sem body. O teste usa apenas query string.' }}</code></pre>
                    </div>

                    {% if selectedTest.query_string %}
                        <div class="block">
                            <h4>Query string</h4>
                            <pre class="code-block"><code>{{ selectedTest.query_string }}</code></pre>
                        </div>
                    {% endif %}

                    {% if selectedTest.last_run %}
                        <div class="block">
                            <h4>Última execução</h4>
                            <div class="chips">
                                <span class="chip{% if selectedTest.last_run.success %} chip-success{% else %} chip-danger{% endif %}">
                                    {{ selectedTest.last_run.success ? 'Sucesso' : 'Falha' }}
                                </span>
                                <span class="chip">HTTP {{ selectedTest.last_run.response_status_code ?? 'n/a' }}</span>
                                <span class="chip">{{ selectedTest.last_run.duration_ms ?? 'n/a' }} ms</span>
                                <span class="chip">Lote {{ selectedTest.last_run.batch_id }}</span>
                            </div>
                            <p class="muted-text">Executado em {{ selectedTest.last_run.executed_at }}.</p>
                        </div>
                    {% endif %}

                    <div class="block">
                        <h4>Última resposta salva</h4>
                        <pre class="code-block"><code>{{ selectedTest.last_response_body ?? 'Nenhuma resposta salva ainda.' }}</code></pre>
                    </div>

                    <div class="block">
                        <h4>Últimos headers salvos</h4>
                        <pre class="code-block"><code>{{ selectedTest.last_response_headers ?? 'Nenhum header salvo ainda.' }}</code></pre>
                    </div>

                    <div class="block">
                        <h4>Captura</h4>
                        <p>Primeira vez em {{ selectedTest.first_recorded_at ?? 'n/a' }} | Última captura em {{ selectedTest.last_recorded_at ?? 'n/a' }}</p>
                    </div>

                    <div class="block">
                        <h4>Histórico recente do cenário</h4>
                        {% if selectedTestRuns is empty %}
                            <p>Nenhuma execução registrada ainda.</p>
                        {% else %}
                            <div class="table-wrap">
                                <table class="results-table">
                                    <thead>
                                        <tr>
                                            <th>Quando</th>
                                            <th>Status</th>
                                            <th>HTTP</th>
                                            <th>Tempo</th>
                                            <th>Lote</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for run in selectedTestRuns %}
                                            <tr>
                                                <td>{{ run.executed_at }}</td>
                                                <td>
                                                    <span class="chip{% if run.success %} chip-success{% else %} chip-danger{% endif %}">
                                                        {{ run.success ? 'ok' : 'erro' }}
                                                    </span>
                                                </td>
                                                <td>{{ run.response_status_code ?? 'n/a' }}</td>
                                                <td>{{ run.duration_ms ?? 'n/a' }} ms</td>
                                                <td>{{ run.batch_id }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div class="empty">Faça um teste pelo API Platform e ele aparecerá aqui como cenário gravado.</div>
            {% endif %}
        </main>
    </section>

    <section class="layout layout-bottom">
        <section class="panel">
            <div class="panel-header">
                <h2>Lote selecionado</h2>
                <p>{% if selectedBatch %}Resultado consolidado da execução {{ selectedBatch.label }}.{% else %}Nenhum lote executado ainda.{% endif %}</p>
            </div>

            {% if selectedBatch %}
                <div class="details">
                    <div class="meta">
                        <span>{{ selectedBatch.run_mode }}</span>
                        <span>{{ selectedBatch.passed_tests }}/{{ selectedBatch.total_tests }} ok</span>
                        <span>{{ selectedBatch.failed_tests }} falhas</span>
                        <span>{{ selectedBatch.started_at }}</span>
                    </div>

                    <div class="table-wrap">
                        <table class="results-table">
                            <thead>
                                <tr>
                                    <th>Ordem</th>
                                    <th>Teste</th>
                                    <th>Grupo</th>
                                    <th>Status</th>
                                    <th>HTTP</th>
                                    <th>Tempo</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for run in batchRuns %}
                                    <tr>
                                        <td>{{ run.execution_order }}</td>
                                        <td>{{ run.test_name }}</td>
                                        <td>{{ run.group_name }}</td>
                                        <td>
                                            <span class="chip{% if run.success %} chip-success{% else %} chip-danger{% endif %}">
                                                {{ run.success ? 'ok' : 'erro' }}
                                            </span>
                                        </td>
                                        <td>{{ run.response_status_code ?? 'n/a' }}</td>
                                        <td>{{ run.duration_ms ?? 'n/a' }} ms</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% if batchRuns is not empty %}
                        {% set firstRun = batchRuns[0] %}
                        <div class="block">
                            <h4>Primeira resposta do lote</h4>
                            <pre class="code-block"><code>{{ firstRun.response_body ?? firstRun.error_message ?? 'Sem retorno registrado.' }}</code></pre>
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <div class="empty">As execuções futuras vão aparecer aqui com histórico, status HTTP e tempo de resposta.</div>
            {% endif %}
        </section>

        <aside class="panel">
            <div class="panel-header">
                <h2>Lotes recentes</h2>
                <p>Navegue pelo histórico persistido das últimas execuções.</p>
            </div>

            {% if recentBatches is empty %}
                <div class="empty">Nenhum lote registrado até o momento.</div>
            {% else %}
                <div class="entity-list compact-list">
                    {% for batch in recentBatches %}
                        <a class="entity-item{% if selectedBatch and selectedBatch.id == batch.id %} is-active{% endif %}" href="{{ app.request.basePath ~ '/index.php/catalogo-testes?lote=' ~ batch.id
                            ~ (selectedGroupCode != '' ? '&grupo=' ~ selectedGroupCode : '')
                            ~ (selectedTest ? '&teste=' ~ selectedTest.code : '')
                            ~ (search != '' ? '&q=' ~ search|url_encode : '')
                        }}">
                            <strong>{{ batch.label }}</strong>
                            <p>{{ batch.run_mode|upper }} | {{ batch.started_at }}</p>
                            <div class="chips">
                                <span class="chip chip-success">{{ batch.passed_tests }} ok</span>
                                <span class="chip chip-danger">{{ batch.failed_tests }} falhas</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </aside>
    </section>
{% endblock %}
