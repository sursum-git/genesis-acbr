{% extends 'catalog/base.html.twig' %}

{% block title %}Catálogo de Programas{% endblock %}

{% block body %}
    <section class="hero">
        <div class="hero-copy">
            <h1>Catálogo de Programas</h1>
            <p>Consulta local do inventário técnico do projeto, com descrição detalhada e histórico de atualização dos módulos cadastrados no banco SQLite.</p>
        </div>
        <div class="hero-stats">
            <article class="stat-card">
                <strong>Total cadastrado</strong>
                <span>{{ programs|length }}</span>
            </article>
            <article class="stat-card">
                <strong>Origem</strong>
                <span>SQLite</span>
            </article>
        </div>
    </section>

    <section class="layout">
        <aside class="panel">
            <div class="panel-header">
                <h2>Programas</h2>
                <p>Filtre por nome, código, caminho ou texto da explicação.</p>
            </div>

            <form class="search-form" method="get" action="{{ path('app_program_catalog') }}">
                <input type="text" name="q" value="{{ search }}" placeholder="Buscar por nfe, cep, schemas, legado...">
                <button class="button button-primary" type="submit">Buscar</button>
                {% if search != '' %}
                    <a class="button button-secondary" href="{{ path('app_program_catalog') }}">Limpar</a>
                {% endif %}
            </form>

            {% if programs is empty %}
                <div class="empty">Nenhum programa encontrado para a busca atual.</div>
            {% else %}
                <div class="entity-list">
                    {% for program in programs %}
                        <a
                            class="entity-item{% if selectedProgram and selectedProgram.code == program.code %} is-active{% endif %}"
                            href="{{ path('app_program_catalog', {
                                programa: program.code,
                                q: search != '' ? search : null
                            }) }}"
                        >
                            <strong>{{ program.name }}</strong>
                            <p>{{ program.description }}</p>
                            <div class="chips">
                                <span class="chip">{{ program.code }}</span>
                                <span class="chip">{{ program.category }}</span>
                                <span class="chip">{{ program.status }}</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </aside>

        <main class="panel">
            {% if selectedProgram %}
                <div class="panel-header">
                    <h2>Detalhes</h2>
                    <p>Estado atual do programa selecionado e seu histórico registrado.</p>
                </div>

                <div class="details">
                    <h3>{{ selectedProgram.name }}</h3>

                    <div class="meta">
                        <span>{{ selectedProgram.code }}</span>
                        <span>{{ selectedProgram.category }}</span>
                        <span>{{ selectedProgram.status }}</span>
                        <span>{{ selectedProgram.path }}</span>
                    </div>

                    <div class="block">
                        <h4>Descrição</h4>
                        <p>{{ selectedProgram.description }}</p>
                    </div>

                    <div class="block">
                        <h4>Caminho físico principal</h4>
                        <pre class="code-block"><code>{{ selectedProgram.physical_path }}</code></pre>
                    </div>

                    <div class="block">
                        <h4>Explicação detalhada</h4>
                        <p>{{ selectedProgram.detailed_explanation }}</p>
                    </div>

                    <div class="block">
                        <h4>Vigência</h4>
                        <p>Início: {{ selectedProgram.started_at }}{% if selectedProgram.ended_at %} | Término: {{ selectedProgram.ended_at }}{% else %} | Sem término registrado{% endif %}</p>
                    </div>

                    <div class="block">
                        <h4>Auditoria</h4>
                        <p>Criado em {{ selectedProgram.created_at|default(selectedProgram.started_at) }} | Atualizado em {{ selectedProgram.updated_at }}</p>
                    </div>

                    <section class="history">
                        <h4>Histórico</h4>

                        {% if history is empty %}
                            <p>Nenhum evento de histórico disponível.</p>
                        {% else %}
                            {% for item in history %}
                                <article class="history-item">
                                    <header>
                                        <strong>{{ item.event_type }}</strong>
                                        <time datetime="{{ item.event_at }}">{{ item.event_at }}</time>
                                    </header>
                                    <p>{{ item.event_summary }}</p>
                                    <div class="chips">
                                        <span class="chip">{{ item.status_snapshot }}</span>
                                        {% if item.started_at_snapshot %}
                                            <span class="chip">Início {{ item.started_at_snapshot }}</span>
                                        {% endif %}
                                        {% if item.ended_at_snapshot %}
                                            <span class="chip">Fim {{ item.ended_at_snapshot }}</span>
                                        {% endif %}
                                    </div>
                                </article>
                            {% endfor %}
                        {% endif %}
                    </section>
                </div>
            {% else %}
                <div class="empty">Nenhum programa disponível para exibir detalhes.</div>
            {% endif %}
        </main>
    </section>
{% endblock %}
