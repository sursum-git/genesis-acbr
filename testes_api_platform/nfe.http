@baseUrl = http://157.173.110.195:8089/index.php
@cnpj = 06013812000158
@uf = ES
@ie = 06013812000158
@chaveNfe = 32260406013812000158550030001955901308939122

### NFe - Status do servico
GET {{baseUrl}}/nfe/consultas/status-servico
Accept: application/ld+json

### NFe - Consulta cadastro por CNPJ
GET {{baseUrl}}/nfe/consultas/consulta-cadastro?AcUF={{uf}}&AnDocumento={{cnpj}}&TipoDocumento=cpf_cnpj
Accept: application/ld+json

### NFe - Consulta cadastro por inscricao estadual
GET {{baseUrl}}/nfe/consultas/consulta-cadastro?AcUF={{uf}}&AnDocumento={{ie}}&TipoDocumento=inscricao_estadual
Accept: application/ld+json

### NFe - Consultar com chave
GET {{baseUrl}}/nfe/consultas/consultar-com-chave?eChaveOuNFe={{chaveNfe}}
Accept: application/ld+json

### NFe - Consultar com XML
POST {{baseUrl}}/nfe/consultas/consultar-com-chave-xml
Content-Type: application/xml
Accept: application/ld+json

<?xml version="1.0"?>
<nfeProc xmlns="http://www.portalfiscal.inf.br/nfe" versao="4.00">
  <NFe>
    <infNFe Id="NFe{{chaveNfe}}" versao="4.00">
      <ide>
        <cUF>32</cUF>
      </ide>
    </infNFe>
  </NFe>
  <protNFe versao="4.00">
    <infProt>
      <chNFe>{{chaveNfe}}</chNFe>
    </infProt>
  </protNFe>
</nfeProc>

### NFe - Enviar assincrono XML com 1 documento
### O endpoint aceita 1 XML e faz fallback automatico para envio sincrono.
POST {{baseUrl}}/nfe/envio/enviar-assincrono-xml?ALote=1
Content-Type: application/xml
Accept: application/ld+json

<?xml version="1.0" encoding="UTF-8"?>
<nfeProc xmlns="http://www.portalfiscal.inf.br/nfe" versao="4.00">
  <NFe xmlns="http://www.portalfiscal.inf.br/nfe">
    <infNFe Id="NFe{{chaveNfe}}" versao="4.00">
      <ide>
        <cUF>32</cUF>
        <tpAmb>2</tpAmb>
      </ide>
    </infNFe>
  </NFe>
</nfeProc>

### NFe - Enviar assincrono XML com 2 documentos concatenados
### Envie um XML completo seguido imediatamente do proximo XML completo no mesmo corpo.
POST {{baseUrl}}/nfe/envio/enviar-assincrono-xml?ALote=1
Content-Type: application/xml
Accept: application/ld+json

<?xml version="1.0" encoding="UTF-8"?>
<nfeProc xmlns="http://www.portalfiscal.inf.br/nfe" versao="4.00">
  <NFe xmlns="http://www.portalfiscal.inf.br/nfe">
    <infNFe Id="NFe32260406013812000158550030001955901308939122" versao="4.00">
      <ide>
        <cUF>32</cUF>
        <tpAmb>2</tpAmb>
      </ide>
    </infNFe>
  </NFe>
</nfeProc>
<?xml version="1.0" encoding="UTF-8"?>
<nfeProc xmlns="http://www.portalfiscal.inf.br/nfe" versao="4.00">
  <NFe xmlns="http://www.portalfiscal.inf.br/nfe">
    <infNFe Id="NFe32260406013812000158550030001955911308939138" versao="4.00">
      <ide>
        <cUF>32</cUF>
        <tpAmb>2</tpAmb>
      </ide>
    </infNFe>
  </NFe>
</nfeProc>

### NFe - Enviar Email
POST {{baseUrl}}/nfe/envio/enviar-email
Accept: application/ld+json
Content-Type: application/ld+json

{
  "payload": {
    "AeArquivoXmlNFe": "/var/www/html/NFe/arqs/06013812000158/NFe/202604/NFe/32260406013812000158550030001955901308939122-nfe.xml",
    "AePara": "pedroparreiras9@gmail.com",
    "AeChaveNFe": "{{chaveNfe}}",
    "AEnviaPDF": 0,
    "AeAssunto": "Envio de NF-e",
    "AeCC": "",
    "AeAnexos": "",
    "AeMensagem": "Segue a NF-e em anexo.",
    "emailNome": "Teste SMTP",
    "emailConta": "teste@example.com",
    "emailServidor": "smtp.gmail.com",
    "emailPorta": "587",
    "emailSSL": "0",
    "emailTLS": "1",
    "emailUsuario": "teste@example.com",
    "emailSenha": "segredo"
  }
}

### NFe - Distribuicao DFe por chave
GET {{baseUrl}}/nfe/distribuicao-dfe/por-chave?AcUFAutor={{uf}}&AeCNPJCPF={{cnpj}}&AechNFe={{chaveNfe}}
Accept: application/ld+json

### NFe - Distribuicao DFe por ultimo NSU
GET {{baseUrl}}/nfe/distribuicao-dfe/por-ult-nsu?AcUFAutor={{uf}}&AeCNPJCPF={{cnpj}}&AeultNSU=000000000000000
Accept: application/ld+json

### NFe - Distribuicao DFe por NSU
GET {{baseUrl}}/nfe/distribuicao-dfe/por-nsu?AcUFAutor={{uf}}&AeCNPJCPF={{cnpj}}&AeNSU=000000000000001
Accept: application/ld+json

### NFe - Consultar recibo
### Substituir ARecibo por um numero de recibo valido.
GET {{baseUrl}}/nfe/consultas/consultar-recibo?ARecibo=SUBSTITUIR_RECIBO
Accept: application/ld+json

### NFe - OpenSSL info
GET {{baseUrl}}/nfe/ferramentas/openssl-info
Accept: application/ld+json

### NFe - Obter certificados
GET {{baseUrl}}/nfe/ferramentas/obter-certificados
Accept: application/ld+json
