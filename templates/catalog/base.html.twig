<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Catálogo{% endblock %}</title>
    <link rel="icon" href="https://raw.githubusercontent.com/Projeto-ACBr-Oficial/Docker/main/PHP/img/favico-acbr.png" type="image/x-icon">
    <link rel="stylesheet" href="{{ app.request.basePath ~ '/catalog-assets/catalog.css' }}">
</head>
<body class="page-body">
    <div class="shell">
        <nav class="catalog-nav">
            <a class="nav-link" href="{{ path('app_home') }}">Hub</a>
            <a class="nav-link{% if app.request.attributes.get('_route') == 'app_program_catalog' %} is-active{% endif %}" href="{{ path('app_program_catalog') }}">Catálogo de Programas</a>
            <a class="nav-link{% if app.request.attributes.get('_route') == 'app_test_catalog' %} is-active{% endif %}" href="{{ path('app_test_catalog') }}">Catálogo de Testes</a>
        </nav>

        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message }}</div>
        {% endfor %}

        {% block body %}{% endblock %}
    </div>
</body>
</html>
