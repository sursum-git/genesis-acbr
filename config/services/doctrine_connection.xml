<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Doctrine\DBAL\Connection"
                 class="Doctrine\DBAL\Connection">
            <factory class="Doctrine\DBAL\DriverManager" method="getConnection"/>
            <argument type="collection">
                <argument key="driver">pdo_sqlite</argument>
                <argument key="path">%kernel.project_dir%/var/db/program_catalog.sqlite</argument>
            </argument>
        </service>
    </services>
</container>
