<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="icon" href="https://raw.githubusercontent.com/Projeto-ACBr-Oficial/Docker/main/PHP/img/favico-acbr.png" type="image/x-icon">
    <style>
        body {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: Arial, sans-serif;
            background-image: url('https://raw.githubusercontent.com/Projeto-ACBr-Oficial/Docker/main/PHP/img/background-php.jpg');
            background-size: cover;
            background-position: center;
        }
        .panel {
            width: min(92vw, 760px);
            padding: 28px 32px;
            border-radius: 18px;
            background: rgba(18, 26, 39, 0.88);
            box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
            color: white;
            text-align: center;
        }
        h1 {
            margin: 0 0 10px;
            font-size: 30px;
        }
        p {
            margin: 0 0 24px;
            color: #d6deeb;
        }
        nav ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        nav li + li {
            margin-top: 10px;
        }
        nav a, .back {
            display: inline-block;
            width: min(100%, 360px);
            padding: 12px 18px;
            border-radius: 10px;
            text-decoration: none;
            color: white;
            background: #333c4e;
            transition: background-color 0.25s;
        }
        nav a:hover, .back:hover {
            background: #f4ad24;
        }
        .back {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="panel">
        <h1>{{ title }}</h1>
        <p>{{ subtitle }}</p>
        <nav>
            <ul>
                {% for item in items %}
                    <li><a href="{{ item.url }}">{{ item.label }}</a></li>
                {% endfor %}
            </ul>
        </nav>
        <a class="back" href="/">Voltar ao Hub</a>
    </div>
</body>
</html>
